{
  "manifest_version": 3,
  "name": "EasyEDA AutoSave",
  "version": "1.0.0",
  "description": "Automatically saves your EasyEDA PCB projects every 10 seconds.",
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": [
    "*://*.easyeda.com/*",
    "*://*.lceda.cn/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.easyeda.com/*",
        "*://*.lceda.cn/*"
      ],
      "js": [
        "src/storageManager.js",
        "src/logger.js",
        "src/editorDetector.js",
        "src/saveTrigger.js",
        "src/intervalManager.js",
        "src/stateWatcher.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "EasyEDA AutoSave",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
